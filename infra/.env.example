# Copia este archivo a .env y ajusta valores en entornos reales.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=placenote
POSTGRES_PASSWORD=placenote_dev_change_me
POSTGRES_DB=placenote

# Secreto para firmar JWT (mínimo 32 caracteres recomendado en producción).
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres
JWT_ISSUER=placenote
JWT_AUDIENCE=placenote-clients

# Alternativa: URL completa (postgresql://usuario:clave@host:puerto/base)
# DATABASE_URL=
